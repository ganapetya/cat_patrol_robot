<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Lower Fast-DDS memory footprint for mapping on 8 GB Jetson.
  Used via FASTRTPS_DEFAULT_PROFILES_FILE in mapping_env.sh / slam_mapping.launch.py
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <participant profile_name="mapping_participant" is_default_profile="true">
        <rtps>
            <allocation>
                <remote_locators>
                    <max_unicast_locators>4</max_unicast_locators>
                    <max_multicast_locators>1</max_multicast_locators>
                </remote_locators>
                <total_participants>
                    <initial>2</initial>
                    <maximum>12</maximum>
                </total_participants>
                <total_readers>
                    <initial>8</initial>
                    <maximum>48</maximum>
                </total_readers>
                <total_writers>
                    <initial>8</initial>
                    <maximum>48</maximum>
                </total_writers>
            </allocation>
        </rtps>
    </participant>
    <data_writer profile_name="mapping_writer" is_default_profile="true">
        <historyMemoryPolicy>PREALLOCATED_WITH_REALLOC</historyMemoryPolicy>
        <qos>
            <history>
                <kind>KEEP_LAST</kind>
                <depth>5</depth>
            </history>
        </qos>
    </data_writer>
    <data_reader profile_name="mapping_reader" is_default_profile="true">
        <historyMemoryPolicy>PREALLOCATED_WITH_REALLOC</historyMemoryPolicy>
        <qos>
            <history>
                <kind>KEEP_LAST</kind>
                <depth>5</depth>
            </history>
        </qos>
    </data_reader>
</profiles>
