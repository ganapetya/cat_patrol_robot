#!/usr/bin/env python3
"""Launcher for cat_patrol_robot.mail_node (ament egg layout uses local/dist-packages)."""
from pathlib import Path
import sys

def _prepend_pkg_path():
  here = Path(__file__).resolve()
  prefix = here.parents[2]
  loc = prefix / 'local' / 'lib'
  for d in sorted(loc.glob('python3.*/dist-packages')):
    sys.path.insert(0, str(d))

_prepend_pkg_path()

from cat_patrol_robot.mail_node import main

if __name__ == '__main__':
  main()
